diff --git a/mnt/data/orr967/source/src/core/hos/splitSleeper.js b/mnt/data/orr967/source/src/core/hos/splitSleeper.js
new file mode 100644
index 0000000..04884ec
--- /dev/null
+++ b/mnt/data/orr967/source/src/core/hos/splitSleeper.js
@@ -0,0 +1,345 @@
+const HOUR = 60;
+
+export const SPLIT_SHORT_MINUTES = 2 * HOUR;
+export const SPLIT_LONG_SLEEPER_MINUTES = 7 * HOUR;
+export const SPLIT_TOTAL_MINUTES = 10 * HOUR;
+export const SPLIT_DRIVE_LIMIT_MINUTES = 11 * HOUR;
+export const SPLIT_SHIFT_LIMIT_MINUTES = 14 * HOUR;
+
+function duration(event = {}) {
+  return Math.max(0, Number(event.endAbs || 0) - Number(event.startAbs || 0));
+}
+
+function sortByStart(events = []) {
+  return [...(events || [])]
+    .filter(Boolean)
+    .filter(event => Number(event.endAbs || 0) > Number(event.startAbs || 0))
+    .sort((a, b) => Number(a.startAbs || 0) - Number(b.startAbs || 0) || Number(a.endAbs || 0) - Number(b.endAbs || 0));
+}
+
+function isRestStatus(status = '') {
+  return status === 'OFF' || status === 'SB';
+}
+
+function isDutyStatus(status = '') {
+  return status === 'ON' || status === 'D';
+}
+
+function mergeBlocks(timeline = [], predicate = () => false, kind = 'rest') {
+  const blocks = [];
+  for (const event of sortByStart(timeline)) {
+    if (!predicate(event)) continue;
+    const eventStart = Number(event.startAbs || 0);
+    const eventEnd = Number(event.endAbs || 0);
+    const last = blocks.at(-1) || null;
+    if (last && eventStart <= last.endAbs + 1) {
+      last.endAbs = Math.max(last.endAbs, eventEnd);
+      last.duration = Math.max(0, last.endAbs - last.startAbs);
+      last.events.push(event);
+      last.statuses.add(event.status);
+      continue;
+    }
+    blocks.push({
+      id:`${kind}_${event.id || eventStart}`,
+      kind,
+      startAbs:eventStart,
+      endAbs:eventEnd,
+      duration:eventEnd - eventStart,
+      events:[event],
+      statuses:new Set([event.status]),
+    });
+  }
+  return blocks;
+}
+
+export function splitRestBlocks(timeline = []) {
+  return mergeBlocks(timeline, event => isRestStatus(event.status), 'rest');
+}
+
+export function splitSleeperBlocks(timeline = []) {
+  return mergeBlocks(timeline, event => event.status === 'SB', 'sleeper');
+}
+
+function overlaps(a = {}, b = {}) {
+  return Number(a.startAbs || 0) < Number(b.endAbs || 0)
+    && Number(b.startAbs || 0) < Number(a.endAbs || 0);
+}
+
+function sumDuration(timeline = [], startAbs = -Infinity, endAbs = Infinity, predicate = () => true) {
+  return sortByStart(timeline).reduce((sum, event) => {
+    if (!predicate(event)) return sum;
+    const start = Math.max(Number(event.startAbs || 0), Number(startAbs));
+    const end = Math.min(Number(event.endAbs || 0), Number(endAbs));
+    return sum + Math.max(0, end - start);
+  }, 0);
+}
+
+function latestFullResetBefore(restBlocks = [], beforeAbs = Infinity) {
+  return restBlocks
+    .filter(block => block.duration >= SPLIT_TOTAL_MINUTES)
+    .map(block => ({ ...block, resetAbs:block.startAbs + SPLIT_TOTAL_MINUTES }))
+    .filter(block => block.resetAbs <= beforeAbs)
+    .sort((a, b) => b.resetAbs - a.resetAbs)[0] || null;
+}
+
+function dutyStartAfter(timeline = [], resetAbs = -Infinity, beforeAbs = Infinity) {
+  const event = sortByStart(timeline).find(item => (
+    isDutyStatus(item.status)
+    && Number(item.endAbs || 0) > resetAbs
+    && Number(item.startAbs || 0) < beforeAbs
+  ));
+  if (!event) return null;
+  return Math.max(Number(event.startAbs || 0), Number(resetAbs));
+}
+
+function priorDutyContext(timeline = [], restBlocks = [], firstPeriod = {}) {
+  const priorReset = latestFullResetBefore(restBlocks, Number(firstPeriod.startAbs || 0));
+  const floor = priorReset ? priorReset.resetAbs : (sortByStart(timeline)[0]?.startAbs ?? Number(firstPeriod.startAbs || 0));
+  const dutyStart = dutyStartAfter(timeline, floor, Number(firstPeriod.startAbs || 0));
+  const driveBefore = sumDuration(
+    timeline,
+    floor,
+    Number(firstPeriod.startAbs || 0),
+    event => event.status === 'D',
+  );
+  const shiftBefore = dutyStart == null ? 0 : Math.max(0, Number(firstPeriod.startAbs || 0) - dutyStart);
+  return { priorReset, floor, dutyStart, driveBefore, shiftBefore };
+}
+
