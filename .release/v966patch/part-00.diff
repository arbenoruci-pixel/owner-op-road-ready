+function splitDriveLimitAbs(timeline = [], startAbs = -Infinity, endAbs = Infinity, allowedDriveMinutes = 0) {
+  let remaining = Math.max(0, Number(allowedDriveMinutes || 0));
+  for (const event of sortByStart(timeline)) {
+    if (event.status !== 'D') continue;
+    const start = Math.max(Number(event.startAbs || 0), Number(startAbs));
+    const end = Math.min(Number(event.endAbs || 0), Number(endAbs));
+    if (end <= start) continue;
+    const duration = end - start;
+    if (duration > remaining) return start + remaining;
+    remaining -= duration;
+  }
+  return null;
+}
+
+function splitShiftLimitAbs(split = {}, currentEndAbs = Infinity) {
+  const startAbs = Number(split.first?.endAbs ?? split.recalculationAbs ?? 0);
+  const allowance = split.pending
+    ? Math.max(0, SPLIT_SHIFT_LIMIT_MINUTES - Number(split.shiftBeforeFirst || 0))
+    : SPLIT_SHIFT_LIMIT_MINUTES;
+  const exclusions = [...(split.excludedPeriods || [])]
+    .filter(Boolean)
+    .map(period => ({ startAbs:Number(period.startAbs || 0), endAbs:Number(period.endAbs || 0) }))
+    .filter(period => period.endAbs > period.startAbs)
+    .sort((a, b) => a.startAbs - b.startAbs);
+
+  let cursor = startAbs;
+  let remaining = allowance;
+  for (const excluded of exclusions) {
+    if (excluded.endAbs <= cursor) continue;
+    const openEnd = Math.min(excluded.startAbs, currentEndAbs);
+    if (openEnd > cursor) {
+      const openDuration = openEnd - cursor;
+      if (openDuration > remaining) return cursor + remaining;
+      remaining -= openDuration;
+    }
+    cursor = Math.max(cursor, excluded.endAbs);
+    if (cursor >= currentEndAbs) return null;
+  }
+  if (currentEndAbs - cursor > remaining) return cursor + remaining;
+  return null;
+}
